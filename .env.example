# ============================================================
# .env — Configurare bot (copiaza ca .env si editeaza)
# ============================================================

# --- Identity ---
BOT_NAME=my_strategy_v1
SYMBOL=BTCUSDT

# Numele strategiei afisat pe chart si in mesajele Telegram (prefix `[NAME]`).
# Daca e gol, se foloseste strategy.name din clasa Python.
STRATEGY_NAME=

# --- Strategy loader ---
STRATEGY_MODULE=strategies.example_strategy
STRATEGY_CLASS=ExampleStrategy

# --- Chart server ---
# Port DIFERIT de vechile boturi (ORB folosea 8080). Scheama:
#   - 8080: ORB v3 (vechi)
#   - 8090: strategie noua 1
#   - 8091: strategie noua 2 ...
CHART_PORT=8090
CHART_TZ=Europe/Bucharest

# --- Account ---
# state.account porneste la ACCOUNT_SIZE si creste/scade DOAR cu PnL real Bybit.
ACCOUNT_SIZE=100.0

# --- State persistence (default OFF: la Restart istoric+equity = 0) ---
# Daca lasi DATA_DIR gol (default), state-ul NU se persista — orice restart
# porneste cu trades=[] si account=ACCOUNT_SIZE. Set DATA_DIR=/data DOAR daca
# vrei sa supravietuiasca state-ul intre restart-uri (in Docker /data e mount-uit
# pe volumul `bot-data`). RESET_TOKEN are efect numai daca DATA_DIR e setat.
DATA_DIR=
RESET_TOKEN=

# --- SL limits (distanta SL fata de entry, in %) ---
# Strategia trebuie sa cheme validate_sl(entry, sl) inainte sa intre in trade.
# Setup-uri cu SL% in afara range-ului sunt skipped.
SL_MIN_PCT=0.15
SL_MAX_PCT=1.50

# --- Leverage cap (siguranta vs respingere ordin pe Bybit) ---
# IMPORTANT: USER-UL TREBUIE SA SETEZE valoarea LEVERAGE_MAX manual pe Bybit
# (UI Bybit -> simbol -> leverage). Botul NU schimba leverage-ul via API.
# Trecuta aici DOAR ca botul sa stie cat sa cap-eze pozitia local (ca Bybit
# sa nu o respinga). Formula cap:
#     notional_max = 0.95 × bybit_balance × LEVERAGE_MAX
# Daca notional dorit > notional_max -> qty se reduce automat.
# LEVERAGE_MAX NU intra in formula sizing-ului (qty = risk × 100 / SL%).
LEVERAGE_MAX=10

# --- Bybit API ---
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=0
BYBIT_CATEGORY=linear

# --- Precision (per symbol — pentru BTCUSDT) ---
QTY_STEP=0.001
QTY_PRECISION=3
PRICE_PRECISION=2

# --- WS kline interval (Bybit: 1 / 3 / 5 / 15 / 30 / 60 / 240 / D) ---
WS_KLINE_INTERVAL=5

# --- REST rate limits (protejeaza contra 10006 / IP ban) ---
# Bybit V5: 120 req/5s public, 10 req/s signed. Defaults conservative.
RATE_LIMIT_PER_SEC=5
RATE_LIMIT_BURST=10

# --- Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
