# ============================================================
# .env — Configurare bot (copiaza ca .env si editeaza)
# ============================================================

# --- Identity ---
BOT_NAME=my_strategy_v1
SYMBOL=BTCUSDT

# Numele strategiei afisat pe chart si in mesajele Telegram (prefix `[NAME]`).
# Daca e gol, se foloseste strategy.name din clasa Python.
STRATEGY_NAME=

# --- Strategy loader ---
STRATEGY_MODULE=strategies.example_strategy
STRATEGY_CLASS=ExampleStrategy

# --- Chart server ---
# Port DIFERIT de vechile boturi (ORB folosea 8080). Scheama:
#   - 8080: ORB v3 (vechi)
#   - 8090: strategie noua 1
#   - 8091: strategie noua 2 ...
CHART_PORT=8090
CHART_TZ=Europe/Bucharest

# --- Account ---
# state.account porneste la ACCOUNT_SIZE si creste/scade cu PnL real Bybit.
# Daca DATA_DIR e setat (default in Docker: /data), state-ul se persista
# intre restart-uri si valoarea actuala a account-ului supravietuieste.
ACCOUNT_SIZE=100.0

# --- State persistence ---
# Director unde se scrie bot_state.json. Lasa gol -> persistenta dezactivata
# (state-ul se reseteaza la fiecare restart). In Dockerfile e setat /data
# si volumul `bot-data` e mount-uit acolo.
DATA_DIR=/data

# Mecanism de reset controlat. Lasa gol -> nimic se reseteaza.
# Schimba valoarea (ex: v1 -> v2) si la urmatorul start statul se sterge
# (account back to ACCOUNT_SIZE, history=[]). Token-ul se persista in
# bot_state.json, deci restart-urile accidentale (crash) nu mai resetează.
RESET_TOKEN=

# --- SL limits ---
SL_MIN_PCT=0.15
SL_MAX_PCT=1.50

# --- Bybit API ---
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=0
BYBIT_CATEGORY=linear

# --- Precision (per symbol — pentru BTCUSDT) ---
QTY_STEP=0.001
QTY_PRECISION=3
PRICE_PRECISION=2

# --- WS kline interval (Bybit: 1 / 3 / 5 / 15 / 30 / 60 / 240 / D) ---
WS_KLINE_INTERVAL=5

# --- REST rate limits (protejeaza contra 10006 / IP ban) ---
# Bybit V5: 120 req/5s public, 10 req/s signed. Defaults conservative.
RATE_LIMIT_PER_SEC=5
RATE_LIMIT_BURST=10

# --- Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
